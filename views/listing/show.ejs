<% layout('/layouts/boilerplate') -%>


    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3>
                <%= listing.title %>
            </h3>
        </div>

        <div class="card listing-card col-6 offset-2 p-0" style="width: 24rem;">
            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="<%= listing.title %>">

            <div class="card-body">

                <p class="card-text">
                    <%= listing.description %>
                </p>

                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <strong>Price:</strong> ₹
                        <%= listing.price %>
                    </li>

                    <li class="list-group-item"><strong>Location:</strong>
                        <%= listing.location %>
                    </li>
                    <li class="list-group-item"><strong>Country:</strong>
                        <%= listing.country %>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Buttons placed properly below the card -->
        <!-- Buttons placed below the card with slight spacing from the bottom -->
        <div class="col-6 offset-2 mt-3 mb-4 d-flex gap-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit this listing</a>

            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
        <div class="col-8 offset-3 mb-3 ">
            <br>
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing.id %>/reviews" method="post">
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating: <span id="ratingValue">3</span> / 5</label>
                    <input type="range" class="form-range" name="review[rating]" min="1" max="5" step="1" id="rating" value="3" oninput="document.getElementById('ratingValue').textContent = this.value;">
                </div>

                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea required name="review[comment]" cols="30" rows="5" class="form-control" id="comment"></textarea>
                </div>
                <button class="btn btn-outline-dark">submit</button>
            </form>

            <hr>
            <p class="fw-bold fs-4">All Reviews</p>
            <div class="row">
                <% for (let review of listing.reviews) { %>
                    <div class="card col-md-5 ms-3 mb-4 shadow-sm border-0 bg-light rounded-4">
                        <div class="card-body">
                            <h5 class="card-title text-dark fw-semibold">
                                <%= review.author || "Jane Doe" %>
                            </h5>
                            <p class="card-text text-secondary">
                                <%= review.comment %>
                            </p>
                            <p class="card-text">
                                <span class="badge bg-success">⭐ <%= review.rating %> / 5</span>
                            </p>
                        </div>
                    </div>
                    <% } %>
            </div>

        </div>

    </div>